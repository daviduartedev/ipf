# Public (Vite) — safe to expose in the browser bundle
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Server-only: one-off migration script `npm run migrate:posts` (never commit real values)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Migração SQL local (`npm run db:migrate-sql`) — URI do Postgres do dashboard (com palavra-passe)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres
#
# Ficheiro em supabase/migrations (opcional; default: primeira migração posts)
# MIGRATION_FILE=20260510120000_posts_category.sql
